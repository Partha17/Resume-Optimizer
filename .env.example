# Google AI Studio key for Gemini 2.0 Flash
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# RapidAPI key with JSearch subscription (free tier: 200 req/mo)
# Get one at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: override model
GEMINI_MODEL=gemini-2.0-flash

# ---------- Tracker (Google Sheets) ----------
# Create a blank Google Sheet, copy the ID from its URL
# (https://docs.google.com/spreadsheets/d/<THIS_PART>/edit), then share it
# with the service-account email from your credentials JSON as an Editor.
GOOGLE_SHEET_ID=your_sheet_id_here
# Path to a Google service-account JSON key with Sheets+Drive scope.
# Easiest path: console.cloud.google.com -> APIs & Services -> Credentials
#   -> Create credentials -> Service account -> add JSON key
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/service_account.json

# ---------- Email watcher (Gmail API, read-only) ----------
# One-time OAuth setup: Google Cloud Console -> APIs -> enable Gmail API
# -> OAuth client (Desktop) -> download client_secret JSON. The first run
# pops a browser, you consent, and the token is cached to GMAIL_TOKEN_JSON.
GMAIL_OAUTH_CLIENT_JSON=./secrets/gmail_client.json
GMAIL_TOKEN_JSON=./secrets/gmail_token.json
